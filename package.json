{
  "name": "memorylane",
  "productName": "MemoryLane",
  "version": "0.13.4",
  "description": "MemoryLane is a system tray application that captures screenshots at regular intervals.",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "cross-env LOG_LEVEL=debug electron-vite dev",
    "dev:debug-pipeline": "cross-env LOG_LEVEL=debug DEBUG_PIPELINE=1 electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:swift": "./scripts/build-swift.sh",
    "build:rust": "node ./scripts/build-rust.js",
    "package": "npm run build && npm run build:swift && electron-builder --dir",
    "make": "npm run build && npm run build:swift && electron-builder --publish never",
    "make:mac": "npm run build && npm run build:swift && electron-builder --mac --publish never",
    "make:win": "npm run build && npm run build:rust && electron-builder --win --publish never",
    "make:linux": "npm run build && electron-builder --linux --publish never",
    "lint": "eslint --ext .ts,.tsx .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node ./scripts/enode.js ./node_modules/vitest/vitest.mjs",
    "test:integration:native-screenshot": "npm run build:swift && cross-env RUN_NATIVE_SCREENSHOT_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/v2/recorder/native-screenshot.integration.test.ts",
    "test:integration:screen-capturer": "npm run build:swift && cross-env RUN_NATIVE_SCREENSHOT_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/v2/recorder/screen-capturer.integration.test.ts",
    "test:e2e:app-watcher-win": "npm run build:rust && cross-env RUN_WINDOWS_E2E=1 electron ./e2e-tests/app-watcher-win-e2e.js",
    "test:integration:video-stitcher": "cross-env RUN_VIDEO_STITCHER_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/v2/video/video-stitcher.integration.test.ts",
    "test:integration:v2-semantic": "cross-env RUN_V2_SEMANTIC_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/v2/activity-semantic-service.integration.test.ts",
    "test:integration:v2-semantic:ollama": "cross-env RUN_V2_SEMANTIC_OLLAMA_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/v2/activity-semantic-service.ollama.integration.test.ts",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky",
    "db:search": "node ./scripts/enode.js ./node_modules/.bin/tsx scripts/db-search.ts",
    "db:stats": "node ./scripts/enode.js ./node_modules/.bin/tsx scripts/db-stats.ts",
    "db:explore": "jupyter notebook tools/explore-db.ipynb",
    "mcp:start": "node ./scripts/enode.js ./node_modules/.bin/tsx scripts/mcp-server.ts",
    "mcp:inspector": "npx @modelcontextprotocol/inspector npm run mcp:start",
    "mcp:dev": "node ./scripts/enode.js ./node_modules/.bin/tsx scripts/mcp-dev.ts on",
    "mcp:dev:off": "node ./scripts/enode.js ./node_modules/.bin/tsx scripts/mcp-dev.ts off",
    "mcp:dev:status": "node ./scripts/enode.js ./node_modules/.bin/tsx scripts/mcp-dev.ts status",
    "install:local": "node ./scripts/install-local.js",
    "detect-patterns": "node ./scripts/enode.js ./node_modules/.bin/tsx scripts/detect-patterns.ts",
    "mcpb:pack": "npx @anthropic-ai/mcpb pack mcpb/"
  },
  "keywords": [],
  "author": {
    "name": "Filip Kubis",
    "email": "fkubis@icloud.com"
  },
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/yazl": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.3",
    "cross-env": "^10.1.0",
    "electron": "40.1.0",
    "electron-builder": "^26.7.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
    "vite": "^5.4.21",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@openrouter/sdk": "^0.5.1",
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color-name": "^1.1.4",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^3.8.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "uiohook-napi": "^1.5.4",
    "uuid": "^13.0.0",
    "yazl": "^3.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
