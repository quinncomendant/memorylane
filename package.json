{
  "name": "memorylane",
  "productName": "MemoryLane",
  "version": "1.0.0",
  "description": "MemoryLane is a system tray application that captures screenshots at regular intervals.",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "rebuild:electron": "electron-builder install-app-deps",
    "rebuild:node": "npm rebuild better-sqlite3",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --dir",
    "make": "npm run build && electron-builder",
    "make:mac": "npm run build && electron-builder --mac",
    "make:win": "npm run build && electron-builder --win",
    "make:linux": "npm run build && electron-builder --linux",
    "lint": "eslint --ext .ts,.tsx .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run rebuild:node && vitest",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky",
    "db:search": "tsx scripts/db-search.ts",
    "db:stats": "tsx scripts/db-stats.ts",
    "mcp:start": "tsx scripts/mcp-server.ts",
    "mcp:inspector": "npx @modelcontextprotocol/inspector npm run mcp:start"
  },
  "keywords": [],
  "author": {
    "name": "Filip Kubis",
    "email": "fkubis@icloud.com"
  },
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "electron": "40.1.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
    "vite": "^5.4.21",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@openrouter/sdk": "^0.5.1",
    "@xenova/transformers": "^2.17.2",
    "active-win": "^8.2.1",
    "better-sqlite3": "^12.6.2",
    "color-name": "^1.1.4",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "sharp": "^0.34.5",
    "sqlite-vec": "^0.1.7-alpha.2",
    "uiohook-napi": "^1.5.4",
    "uuid": "^13.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
