{
  "name": "memorylane",
  "productName": "MemoryLane",
  "version": "0.21.0",
  "description": "MemoryLane is a system tray application that captures screenshots at regular intervals.",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "cross-env LOG_LEVEL=debug electron-vite dev",
    "dev:debug-pipeline": "cross-env LOG_LEVEL=debug DEBUG_PIPELINE=1 electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:swift": "./scripts/build-swift.sh",
    "build:rust": "node ./scripts/build-rust.js",
    "build:model": "node ./scripts/download-model.js",
    "package": "npm run build && npm run build:swift && electron-builder --config electron-builder.config.js --dir",
    "make": "npm run build && npm run build:swift && npm run build:model && electron-builder --config electron-builder.config.js --publish never",
    "make:mac": "npm run build && npm run build:swift && npm run build:model && electron-builder --config electron-builder.config.js --mac --publish never",
    "make:win": "npm run build && npm run build:rust && npm run build:model && electron-builder --config electron-builder.config.js --win --publish never",
    "make:customer:mac": "cross-env EDITION=customer npm run make:mac",
    "make:enterprise:mac": "node -e \"console.error('Enterprise builds are Windows MSI-only.'); process.exit(1)\"",
    "make:customer:win": "cross-env EDITION=customer npm run make:win",
    "make:enterprise:win": "cross-env EDITION=enterprise npm run make:win",
    "make:win:signed": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/make-win-signed.ps1",
    "lint": "eslint --ext .ts,.tsx .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node ./scripts/enode.js ./node_modules/vitest/vitest.mjs",
    "test:integration:native-screenshot": "npm run build:swift && cross-env RUN_NATIVE_SCREENSHOT_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/recorder/native-screenshot.integration.test.ts",
    "test:integration:native-screenshot:win": "npm run build:rust && cross-env RUN_WINDOWS_NATIVE_SCREENSHOT_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/recorder/native-screenshot.windows.integration.test.ts",
    "test:integration:screen-capturer": "npm run build:swift && cross-env RUN_NATIVE_SCREENSHOT_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/recorder/screen-capturer.integration.test.ts",
    "test:integration:screen-capturer:win": "npm run build:rust && cross-env RUN_WINDOWS_NATIVE_SCREENSHOT_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/recorder/screen-capturer.windows.integration.test.ts",
    "test:integration:video-stitcher": "cross-env RUN_VIDEO_STITCHER_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/video/video-stitcher.integration.test.ts",
    "test:integration:semantic": "cross-env RUN_SEMANTIC_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/activity-semantic-service.integration.test.ts",
    "test:integration:semantic:ollama": "cross-env RUN_SEMANTIC_OLLAMA_INTEGRATION=1 node ./scripts/enode.js ./node_modules/vitest/vitest.mjs src/main/activity-semantic-service.ollama.integration.test.ts",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky",
    "debug:app-watcher": "node ./scripts/enode.js ./node_modules/tsx/dist/cli.mjs scripts/app-watcher-dump.ts",
    "db:search": "node ./scripts/enode.js ./node_modules/tsx/dist/cli.mjs scripts/db-search.ts",
    "db:stats": "node ./scripts/enode.js ./node_modules/tsx/dist/cli.mjs scripts/db-stats.ts",
    "mcp:start": "node ./scripts/enode.js ./node_modules/tsx/dist/cli.mjs scripts/mcp-server.ts",
    "mcp:inspector": "npx @modelcontextprotocol/inspector npm run mcp:start",
    "install:local": "node ./scripts/install-local.js",
    "sign:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sign-windows.ps1",
    "detect-patterns": "node ./scripts/enode.js ./node_modules/tsx/dist/cli.mjs scripts/detect-patterns.ts",
    "detect-patterns:prune": "node ./scripts/enode.js ./node_modules/tsx/dist/cli.mjs scripts/prune-patterns.ts",
    "build-user-context": "node ./scripts/enode.js ./node_modules/tsx/dist/cli.mjs scripts/build-user-context.ts",
    "mcpb:pack": "npx @anthropic-ai/mcpb pack mcpb/",
    "cli:build": "cd packages/cli && npm run build",
    "cli:test": "cd packages/cli && npm test",
    "cli:link": "cd packages/cli && npm link"
  },
  "keywords": [],
  "author": {
    "name": "Filip Kubis",
    "email": "fkubis@icloud.com"
  },
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/yazl": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.3",
    "cross-env": "^10.1.0",
    "electron": "40.1.0",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@huggingface/transformers": "^3.8.1",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@openrouter/sdk": "^0.5.1",
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color-name": "^1.1.4",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.563.0",
    "openai": "^6.27.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^3.8.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "uiohook-napi": "^1.5.4",
    "uuid": "^13.0.0",
    "yazl": "^3.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
