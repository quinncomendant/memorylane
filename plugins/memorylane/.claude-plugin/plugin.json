{
  "name": "memorylane",
  "description": "Search and reason over your screen activity history — what you worked on, when, and in which apps.",
  "version": "0.12.1",
  "author": {
    "name": "MemoryLane Team",
    "email": "hello@trymemorylane.com"
  },
  "commands": ["./commands/"],
  "mcpServers": {
    "memorylane": {
      "command": "/Applications/MemoryLane.app/Contents/MacOS/MemoryLane",
      "args": ["/Applications/MemoryLane.app/Contents/Resources/app.asar/out/main/mcp-entry.js"],
      "env": {
        "ELECTRON_RUN_AS_NODE": "1"
      }
    }
  }
}
